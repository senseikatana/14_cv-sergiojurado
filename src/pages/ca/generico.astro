---
import Base from '../../layouts/Base.astro';
const mainHtml = '<main class="container-x py-12 sm:py-16">  <!-- Cabecera solo impresión --><div class="print-only hidden mb-4"> <h1 class="font-display text-2xl">Sergio Jurado</h1> <p class="text-sm text-ink-soft">Professional polivalent · Orientat a resultats</p> <p class="mt-1 text-xs text-ink-muted"> [tu-email] · [tu-teléfono] · Terrassa, Catalunya · [tu-web] </p> <div class="rule mt-3"></div> </div> <!-- Hero --> <section class="reveal mb-12 sm:mb-16"> <p class="eyebrow">Perfil Genèric</p> <h1 class="mt-3 text-hero text-[clamp(2.25rem,7vw,4.5rem)] leading-[1.02]">Professional polivalent · Orientat a resultats</h1> <p class="mt-5 max-w-prose text-base leading-relaxed text-ink-soft sm:text-lg">Persona resolutiva, organitzada i amb ganes d’aportar valor a qualsevol equip.</p> <div class="no-print mt-7 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-muted"> <span>Terrassa, Catalunya</span> <a href="mailto:[tu-email]" class="link-underline">[tu-email]</a> <span>[tu-teléfono]</span> </div> </section> <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]"> <!-- Columna izquierda --> <div class="space-y-10"> <section class="avoid-break"> <h2 class="eyebrow mb-4">Sobre mi</h2> <p class="text-[0.95rem] leading-relaxed text-ink-soft">Professional versàtil amb capacitat d’adaptació, comunicació i treball en equip. Combino rigor i orientació al detall amb una actitud proactiva per assumir nous reptes i aprendre ràpid.</p> </section> <section class="avoid-break"> <h2 class="eyebrow mb-4">Habilitats</h2> <ul class="flex flex-wrap gap-2"> <li class="chip">Comunicació i treball en equip</li><li class="chip">Organització i gestió del temps</li><li class="chip">Resolució de problemes</li><li class="chip">Atenció al client</li><li class="chip">Ofimàtica (Office / Google)</li><li class="chip">Idiomes: Espanyol, Català, Anglès (B2)</li><li class="chip">Adaptabilitat</li><li class="chip">Iniciativa i proactivitat</li> </ul> </section> <section class="avoid-break"> <h2 class="eyebrow mb-4">Formació</h2> <ul class="space-y-4"> <li> <p class="text-[0.95rem] font-medium text-ink">Grau en Administració i Direcció d’Empreses</p> <p class="text-sm text-ink-muted">Universitat · 2014 — 2018</p> </li><li> <p class="text-[0.95rem] font-medium text-ink">Curs de Gestió de Projectes</p> <p class="text-sm text-ink-muted">Centre de Formació · 2020</p> </li> </ul> </section> </div> <!-- Columna derecha --> <div class="space-y-12"> <section> <h2 class="eyebrow mb-6">Experiència</h2> <div class="space-y-8"> <article class="avoid-break border-l-2 border-line pl-5"> <div class="flex flex-wrap items-baseline justify-between gap-x-4"> <h3 class="font-display text-xl">Coordinador de projectes</h3> <span class="text-sm text-ink-muted">2021 — Actualitat</span> </div> <p class="mt-0.5 text-sm font-medium text-accent">Empresa de serveis</p> <ul class="mt-3 space-y-1.5"> <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Coordinació de tasques entre departaments i seguiment d’objectius.</span> </li><li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Millora de processos interns i reporting periòdic a direcció.</span> </li> </ul> </article><article class="avoid-break border-l-2 border-line pl-5"> <div class="flex flex-wrap items-baseline justify-between gap-x-4"> <h3 class="font-display text-xl">Atenció al client</h3> <span class="text-sm text-ink-muted">2018 — 2021</span> </div> <p class="mt-0.5 text-sm font-medium text-accent">Comerç / Serveis</p> <ul class="mt-3 space-y-1.5"> <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Gestió d’incidències i suport directe a clients.</span> </li><li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Reconeixement per satisfacció del client i resolució eficaç.</span> </li> </ul> </article> </div> </section> <section> <h2 class="eyebrow mb-6">Projectes destacats</h2> <div class="grid gap-4 sm:grid-cols-2"> <a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Projecte personal</span> <h3 class="mt-2 font-display text-lg leading-snug">Portfolio personal</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Monorepo amb el meu portfolio i múltiples projectes web: botigues, apps i plantilles. Construït amb Astro i TypeScript.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> Veure a GitHub </span> </a><a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Contingut · Documentació</span> <h3 class="mt-2 font-display text-lg leading-snug">Receptes naturals</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Recopilació de receptes casolanes i productes naturals documentats pas a pas. Un projecte personal d’organització de coneixement.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> Veure a GitHub </span> </a><a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Web · Catàleg</span> <h3 class="mt-2 font-display text-lg leading-snug">Num Perfumes</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Projecte web de catàleg de perfums amb Astro, orientat a una presentació cuidada de producte.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> Veure a GitHub </span> </a> </div> </section> </div> </div>  </main>';
---
<Base
  lang="ca"
  accent="violet"
  title="Perfil Genèric · Sergio Jurado"
  description="Persona resolutiva, organitzada i amb ganes d’aportar valor a qualsevol equip."
  activeVariant="generico"
  activeLang="ca"
