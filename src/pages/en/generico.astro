---
import Base from '../../layouts/Base.astro';
const mainHtml = '<main class="container-x py-12 sm:py-16">  <!-- Cabecera solo impresión --><div class="print-only hidden mb-4"> <h1 class="font-display text-2xl">Sergio Jurado</h1> <p class="text-sm text-ink-soft">Versatile professional · Results-driven</p> <p class="mt-1 text-xs text-ink-muted"> [tu-email] · [tu-teléfono] · Terrassa, Catalonia · [tu-web] </p> <div class="rule mt-3"></div> </div> <!-- Hero --> <section class="reveal mb-12 sm:mb-16"> <p class="eyebrow">Generic Profile</p> <h1 class="mt-3 text-hero text-[clamp(2.25rem,7vw,4.5rem)] leading-[1.02]">Versatile professional · Results-driven</h1> <p class="mt-5 max-w-prose text-base leading-relaxed text-ink-soft sm:text-lg">Resourceful, organised and eager to add value to any team.</p> <div class="no-print mt-7 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-muted"> <span>Terrassa, Catalonia</span> <a href="mailto:[tu-email]" class="link-underline">[tu-email]</a> <span>[tu-teléfono]</span> </div> </section> <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]"> <!-- Columna izquierda --> <div class="space-y-10"> <section class="avoid-break"> <h2 class="eyebrow mb-4">About me</h2> <p class="text-[0.95rem] leading-relaxed text-ink-soft">Versatile professional with strong adaptability, communication and teamwork. I combine rigour and attention to detail with a proactive attitude to take on new challenges and learn fast.</p> </section> <section class="avoid-break"> <h2 class="eyebrow mb-4">Skills</h2> <ul class="flex flex-wrap gap-2"> <li class="chip">Communication &amp; teamwork</li><li class="chip">Organisation &amp; time management</li><li class="chip">Problem solving</li><li class="chip">Customer service</li><li class="chip">Office tools (Office / Google)</li><li class="chip">Languages: Spanish, Catalan, English (B2)</li><li class="chip">Adaptability</li><li class="chip">Initiative &amp; proactivity</li> </ul> </section> <section class="avoid-break"> <h2 class="eyebrow mb-4">Education</h2> <ul class="space-y-4"> <li> <p class="text-[0.95rem] font-medium text-ink">BBA — Business Administration &amp; Management</p> <p class="text-sm text-ink-muted">University · 2014 — 2018</p> </li><li> <p class="text-[0.95rem] font-medium text-ink">Project Management course</p> <p class="text-sm text-ink-muted">Training Centre · 2020</p> </li> </ul> </section> </div> <!-- Columna derecha --> <div class="space-y-12"> <section> <h2 class="eyebrow mb-6">Experience</h2> <div class="space-y-8"> <article class="avoid-break border-l-2 border-line pl-5"> <div class="flex flex-wrap items-baseline justify-between gap-x-4"> <h3 class="font-display text-xl">Project Coordinator</h3> <span class="text-sm text-ink-muted">2021 — Present</span> </div> <p class="mt-0.5 text-sm font-medium text-accent">Services company</p> <ul class="mt-3 space-y-1.5"> <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Coordinated tasks across departments and tracked objectives.</span> </li><li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Improved internal processes and provided periodic reporting to management.</span> </li> </ul> </article><article class="avoid-break border-l-2 border-line pl-5"> <div class="flex flex-wrap items-baseline justify-between gap-x-4"> <h3 class="font-display text-xl">Customer Service</h3> <span class="text-sm text-ink-muted">2018 — 2021</span> </div> <p class="mt-0.5 text-sm font-medium text-accent">Retail / Services</p> <ul class="mt-3 space-y-1.5"> <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Handled incidents and provided direct customer support.</span> </li><li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Recognised for customer satisfaction and effective problem solving.</span> </li> </ul> </article> </div> </section> <section> <h2 class="eyebrow mb-6">Featured projects</h2> <div class="grid gap-4 sm:grid-cols-2"> <a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Personal project</span> <h3 class="mt-2 font-display text-lg leading-snug">Personal portfolio</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Monorepo with my portfolio and multiple web projects: shops, apps and templates. Built with Astro and TypeScript.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> View on GitHub </span> </a><a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Content · Documentation</span> <h3 class="mt-2 font-display text-lg leading-snug">Natural recipes</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">A collection of homemade recipes and natural products documented step by step. A personal knowledge-organisation project.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> View on GitHub </span> </a><a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Web · Catalogue</span> <h3 class="mt-2 font-display text-lg leading-snug">Num Perfumes</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Perfume catalogue web project with Astro, focused on careful product presentation.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> View on GitHub </span> </a> </div> </section> </div> </div>  </main>';
---
<Base
  lang="en"
  accent="violet"
  title="Generic Profile · Sergio Jurado"
  description="Resourceful, organised and eager to add value to any team."
