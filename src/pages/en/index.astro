---
import Base from '../../layouts/Base.astro';
const mainHtml = '<main class="container-x py-12 sm:py-16">   <section class="reveal pt-8 pb-12 sm:pt-16 sm:pb-16"> <p class="eyebrow">Portfolio · Digital CV</p> <h1 class="mt-4 max-w-4xl text-hero">Hi, I&#39;m Sergio Jurado.</h1> <p class="mt-6 max-w-prose text-base leading-relaxed text-ink-soft sm:text-lg">Three profiles, one mindset: rigour, attention to detail and a real drive to contribute. Pick the version that best fits what you need — each one is ready to view and print.</p> </section> <div class="rule"></div>  <section class="reveal py-12 sm:py-16"> <h2 class="eyebrow mb-8">Choose a profile</h2> <div class="grid gap-6 md:grid-cols-3"> <a href="/en/logistica" data-accent="terra" class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper-card p-7 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-[0_18px_40px_-22px_rgba(0,0,0,0.35)]"> <span class="absolute inset-x-0 top-0 h-[3px] origin-left scale-x-0 bg-gradient-to-r from-accent to-accent-soft transition-transform duration-300 group-hover:scale-x-100"></span> <span class="inline-block h-10 w-10 rounded-full border-[1.5px] border-accent bg-accent/10"></span> <h3 class="mt-5 font-display text-2xl leading-tight">Logistics &amp; Warehouse</h3> <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">Warehouse coordination, stock control and optimisation of picking and dispatch processes.</p> <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-accent"> View CV <span class="transition-transform group-hover:translate-x-1">→</span> </span> </a><a href="/en/fullstack" data-accent="teal" class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper-card p-7 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-[0_18px_40px_-22px_rgba(0,0,0,0.35)]"> <span class="absolute inset-x-0 top-0 h-[3px] origin-left scale-x-0 bg-gradient-to-r from-accent to-accent-soft transition-transform duration-300 group-hover:scale-x-100"></span> <span class="inline-block h-10 w-10 rounded-full border-[1.5px] border-accent bg-accent/10"></span> <h3 class="mt-5 font-display text-2xl leading-tight">Fullstack &amp; Digital Creative</h3> <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">I build fast, beautiful web products from concept to deployment, with care for visual detail.</p> <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-accent"> View CV <span class="transition-transform group-hover:translate-x-1">→</span> </span> </a><a href="/en/generico" data-accent="violet" class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper-card p-7 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-[0_18px_40px_-22px_rgba(0,0,0,0.35)]"> <span class="absolute inset-x-0 top-0 h-[3px] origin-left scale-x-0 bg-gradient-to-r from-accent to-accent-soft transition-transform duration-300 group-hover:scale-x-100"></span> <span class="inline-block h-10 w-10 rounded-full border-[1.5px] border-accent bg-accent/10"></span> <h3 class="mt-5 font-display text-2xl leading-tight">Generic Profile</h3> <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">Resourceful, organised and eager to add value to any team.</p> <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-accent"> View CV <span class="transition-transform group-hover:translate-x-1">→</span> </span> </a> </div> </section>  </main>';
---
<Base
  lang="en"
  accent="terra"
  title="Sergio Jurado · Portfolio · Digital CV"
  description="Portfolio creativo y CV digital de Sergio Jurado."
  activeVariant="home"
  activeLang="en"
>
  <fragment set:html={mainHtml} />
</Base>
