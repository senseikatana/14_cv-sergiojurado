---
import Base from '../../layouts/Base.astro';
const mainHtml = '<main class="container-x py-12 sm:py-16">  <!-- Cabecera solo impresión --><div class="print-only hidden mb-4"> <h1 class="font-display text-2xl">Sergio Jurado</h1> <p class="text-sm text-ink-soft">Operario de Logística y Gestión de Almacén</p> <p class="mt-1 text-xs text-ink-muted"> [tu-email] · [tu-teléfono] · Terrassa, Catalunya · [tu-web] </p> <div class="rule mt-3"></div> </div> <!-- Hero --> <section class="reveal mb-12 sm:mb-16"> <p class="eyebrow">Logística y Almacén</p> <h1 class="mt-3 text-hero text-[clamp(2.25rem,7vw,4.5rem)] leading-[1.02]">Operario de Logística y Gestión de Almacén</h1> <p class="mt-5 max-w-prose text-base leading-relaxed text-ink-soft sm:text-lg">Coordinación de almacén, control de stock y optimización de procesos de picking y expedición.</p> <div class="no-print mt-7 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-muted"> <span>Terrassa, Catalunya</span> <a href="mailto:[tu-email]" class="link-underline">[tu-email]</a> <span>[tu-teléfono]</span> </div> </section> <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]"> <!-- Columna izquierda --> <div class="space-y-10"> <section class="avoid-break"> <h2 class="eyebrow mb-4">Sobre mí</h2> <p class="text-[0.95rem] leading-relaxed text-ink-soft">Profesional de logística orientado a la eficiencia y la precisión. Experiencia en recepción de mercancía, gestión de inventario con SGA, preparación de pedidos y manejo de carretilla. Comprometido con la seguridad, el orden y los plazos de entrega.</p> </section> <section class="avoid-break"> <h2 class="eyebrow mb-4">Habilidades</h2> <ul class="flex flex-wrap gap-2"> <li class="chip">Gestión de inventario (SGA/WMS)</li><li class="chip">Picking y packing</li><li class="chip">Carretilla elevadora (carné vigente)</li><li class="chip">Control de stock y recuento cíclico</li><li class="chip">Recepción y expedición</li><li class="chip">Prevención de riesgos (PRL)</li><li class="chip">Optimización de rutas internas</li><li class="chip">Excel y ERP logístico</li> </ul> </section> <section class="avoid-break"> <h2 class="eyebrow mb-4">Formación</h2> <ul class="space-y-4"> <li> <p class="text-[0.95rem] font-medium text-ink">Grado Medio en Actividades Comerciales</p> <p class="text-sm text-ink-muted">IES · 2017 — 2019</p> </li><li> <p class="text-[0.95rem] font-medium text-ink">Carné de carretillero + PRL</p> <p class="text-sm text-ink-muted">Centro de Formación Logística · 2019</p> </li> </ul> </section> </div> <!-- Columna derecha --> <div class="space-y-12"> <section> <h2 class="eyebrow mb-6">Experiencia</h2> <div class="space-y-8"> <article class="avoid-break border-l-2 border-line pl-5"> <div class="flex flex-wrap items-baseline justify-between gap-x-4"> <h3 class="font-display text-xl">Responsable de turno de almacén</h3> <span class="text-sm text-ink-muted">2022 — Presente</span> </div> <p class="mt-0.5 text-sm font-medium text-accent">DistriCentro Logística</p> <ul class="mt-3 space-y-1.5"> <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Coordinación de un equipo de 8 operarios y planificación diaria de tareas.</span> </li><li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Reducción del 18% en errores de preparación mediante doble verificación.</span> </li><li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Implantación de recuento cíclico que mejoró la fiabilidad de stock al 99,2%.</span> </li> </ul> </article><article class="avoid-break border-l-2 border-line pl-5"> <div class="flex flex-wrap items-baseline justify-between gap-x-4"> <h3 class="font-display text-xl">Operario de almacén</h3> <span class="text-sm text-ink-muted">2019 — 2022</span> </div> <p class="mt-0.5 text-sm font-medium text-accent">LogiPack Ibérica</p> <ul class="mt-3 space-y-1.5"> <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Preparación de más de 250 pedidos diarios con sistema de radiofrecuencia.</span> </li><li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft"> <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span> <span>Manejo de carretilla frontal y retráctil en zonas de gran volumen.</span> </li> </ul> </article> </div> </section> <section> <h2 class="eyebrow mb-6">Proyectos destacados</h2> <div class="grid gap-4 sm:grid-cols-2"> <a href="https://github.com/senseikatana/sga-vilaseca" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">WMS · Gestión de almacén</span> <h3 class="mt-2 font-display text-lg leading-snug">Novatecnica SGA</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Sistema de gestión de almacén (WMS) en tiempo real: control de inventario multiubicación, picking por olas, recepción, conteo cíclico y dashboards de KPIs.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> Ver en GitHub </span> </a><a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Logística · Inventario</span> <h3 class="mt-2 font-display text-lg leading-snug">Warehouse Manager</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Aplicación de gestión de almacén con backend y frontend: seguimiento de stock, tareas de operario y trazabilidad de movimientos entre zonas.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> Ver en GitHub </span> </a><a href="https://github.com/senseikatana" target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm"> <span class="text-[0.7rem] uppercase tracking-wider text-accent">Automatización</span> <h3 class="mt-2 font-display text-lg leading-snug">Snippets y utilidades de sistema</h3> <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">Colección de scripts de utilidades (discos, red/VPN, rescate SSH) útiles para la operativa diaria y el mantenimiento de equipos.</p> <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent"> <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"> <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path> </svg> Ver en GitHub </span> </a> </div> </section> </div> </div>  </main>';
---
<Base
  lang="es"
  accent="terra"
  title="Logística y Almacén · Sergio Jurado"
  description="Coordinación de almacén, control de stock y optimización de procesos de picking y expedición."
  activeVariant="logistica"
  activeLang="es"
>
  <fragment set:html={mainHtml} />
</Base>
