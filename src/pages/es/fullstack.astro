<Base
  lang="es"
  accent="teal"
  title="Fullstack &amp;amp; Creativo Digital · Sergio Jurado"
  description="Construyo productos web rápidos y bonitos, del concepto al despliegue, cuidando el detalle visual."
  activeVariant="fullstack"
